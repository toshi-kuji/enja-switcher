---
interface Props {
  title: string;
  description: string;
  lang: 'ja' | 'en';
  alternateUrl: string;
}

const { title, description, lang, alternateUrl } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://toshi-kuji.github.io/enja-switcher';
const currentUrl = siteUrl + new URL(Astro.url.pathname, siteUrl).pathname;
const ogImage = siteUrl + '/og-image.png';
const alternateLang = lang === 'ja' ? 'en' : 'ja';
const alternateFull = siteUrl + alternateUrl;

const isJa = lang === 'ja';
const navLabels = {
  license: isJa ? 'ライセンス' : 'License',
  disclaimer: isJa ? '免責事項' : 'Disclaimer',
  sponsorEmoji: '☕',
  sponsor: isJa ? '開発を支援する' : 'Sponsor',
  feedback: isJa ? 'フィードバック' : 'Feedback',
  releases: isJa ? '過去のバージョン' : 'Past Releases',
  switchLang: isJa ? 'English' : '日本語',
};
const licensePath = isJa ? `${base}license/` : `${base}en/license/`;
const disclaimerPath = isJa ? `${base}disclaimer/` : `${base}en/disclaimer/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    <link rel="icon" href={`${base}favicon.ico`} />

    <!-- hreflang -->
    <link rel="alternate" hreflang={lang} href={currentUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateFull} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />

    <meta name="generator" content={Astro.generator} />

    <style>
      /* ===== Reset & Base ===== */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.7;
        color: #1a3d5c;
        background: #f5fbfd;
      }

      a {
        color: #3a8fb7;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      /* ===== Header ===== */
      .site-header {
        border-bottom: 1px solid #c8e2ec;
        padding: 0.75rem 1.5rem;
        background: rgba(245, 251, 253, 0.9);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 1.5rem;
        list-style: none;
        font-size: 0.85rem;
      }

      .header-nav a {
        color: #5a8a9e;
      }

      .header-nav a:hover {
        color: #1a3d5c;
      }

      .sponsor-emoji {
        font-size: 1.1em;
        vertical-align: middle;
      }

      /* ===== Footer ===== */
      .site-footer {
        border-top: 1px solid #c8e2ec;
        padding: 1.5rem 1.5rem;
        margin-top: 4rem;
        text-align: center;
        font-size: 0.8rem;
        color: #5a8a9e;
      }

      /* ===== Responsive ===== */
      @media (max-width: 600px) {
        .header-nav {
          gap: 0.4rem 1rem;
          font-size: 0.8rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav aria-label={isJa ? 'メインナビ' : 'Main navigation'}>
        <ul class="header-nav">
          <li><a href={isJa ? base : `${base}en/`}>EnJaSwitcher</a></li>
          <li><a href={licensePath}>{navLabels.license}</a></li>
          <li><a href={disclaimerPath}>{navLabels.disclaimer}</a></li>
          <li><span class="sponsor-emoji">{navLabels.sponsorEmoji}</span> <a href="https://github.com/sponsors/toshi-kuji" target="_blank" rel="noopener noreferrer">{navLabels.sponsor}</a></li>
          <li><a href="https://docs.google.com/forms/d/e/PLACEHOLDER/viewform" target="_blank" rel="noopener noreferrer">{navLabels.feedback}</a></li>
          <li><a href="https://github.com/toshi-kuji/enja-switcher/releases" target="_blank" rel="noopener noreferrer">{navLabels.releases}</a></li>
          <li><a href={alternateUrl}>{navLabels.switchLang}</a></li>
        </ul>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>&copy; 2026 Toshiaki Kujime. MIT License.</p>
    </footer>
  </body>
</html>
