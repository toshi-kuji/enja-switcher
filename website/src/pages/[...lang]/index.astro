---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import jaJson from '../../i18n/ja.json';
import enJson from '../../i18n/en.json';

const screenshots = import.meta.glob<{ default: ImageMetadata }>('../../assets/screenshots/*.png', { eager: true });
function getScreenshot(filename: string) {
  const key = `../../assets/screenshots/${filename}`;
  return screenshots[key]?.default;
}

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { t: jaJson, lang: 'ja' as const } },
    { params: { lang: 'en' }, props: { t: enJson, lang: 'en' as const } },
  ];
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;

// Fetch latest release version from GitHub API at build time
let latestVersion = "1.0.0";
let downloadUrl = "https://github.com/toshi-kuji/enja-switcher/releases/download/v1.0.0/EnJaSwitcher.app.zip";
try {
  const res = await fetch("https://api.github.com/repos/toshi-kuji/enja-switcher/releases/latest", {
    headers: { "Accept": "application/vnd.github.v3+json" },
  });
  if (res.ok) {
    const data = await res.json();
    const tag = data.tag_name || "v1.0.0";
    latestVersion = tag.replace(/^v/, "");
    downloadUrl = `https://github.com/toshi-kuji/enja-switcher/releases/download/${tag}/EnJaSwitcher.app.zip`;
  }
} catch {
  // Fallback to hardcoded values on error
}
const isJa = lang === 'ja';
const title = isJa
  ? 'EnJaSwitcher - macOS 英数/かな 入力ソース切り替えアプリ'
  : 'EnJaSwitcher - macOS Input Source Switcher (Eisuu/Kana)';
const description = isJa
  ? '左⌘で英数、右⌘でかな。macOS の入力ソースをコマンドキーで迷わず切り替えるメニューバーアプリ。'
  : 'Left ⌘ for Eisuu, Right ⌘ for Kana. A macOS menu bar app that switches input source with Command key — no guessing.';
const alternateUrl = isJa ? `${base}en/` : `${base}`;
---

<Layout {title} {description} {lang} {alternateUrl}>
  <main>
    <!-- Hero -->
    <section class="hero" id="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-art">
            <img src={`${base}icon.svg`} alt="EnJaSwitcher" class="hero-icon" />
          </div>
          <div class="hero-text">
            <h1 class="hero-title">EnJaSwitcher</h1>
            <p class="hero-subtitle">{t.hero.headline}</p>
          </div>
        </div>
        <div class="hero-action">
          <a href={downloadUrl} class="btn-download">{isJa ? `ダウンロード v${latestVersion}` : `Download v${latestVersion}`}</a>
          <p class="hero-meta">macOS 13+ | Free &amp; Open Source | <a href="https://github.com/toshi-kuji/enja-switcher" target="_blank" rel="noopener noreferrer">{isJa ? 'GitHub はこちら' : 'View on GitHub'}</a></p>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
      <div class="container">
        <h2 class="section-title">{t.features.heading}</h2>
        {t.features.items.map((feature: { emoji: string; title: string; description: string; screenshot: string }, i: number) => (
          <div class={`feature-row ${i % 2 === 1 ? 'feature-row--reverse' : ''}`}>
            <div class="feature-text">
              <h3><span class="feature-emoji">{feature.emoji}</span> {feature.title}</h3>
              <div class="feature-desc">
                <p set:html={feature.description.replace(/\n/g, '<br>')} />
              </div>
            </div>
            <div class="feature-screenshot">
              {getScreenshot(feature.screenshot) && (
                <Image src={getScreenshot(feature.screenshot)} alt={feature.title} class="screenshot-img" />
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Install -->
    <section class="install" id="install">
      <div class="container">
        <h2 class="section-title">{t.install.heading}</h2>
        <ol class="steps">
          {t.install.steps.map((step: { title: string; description: string; readmeLink?: string }) => (
            <li class="step">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
              {step.readmeLink && <p><a href={step.readmeLink}>→ README</a></p>}
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Permissions -->
    <section class="permissions" id="permissions">
      <div class="container">
        <h2 class="section-title">{t.permissions.heading}</h2>
        <p class="section-desc">{t.permissions.intro}</p>
        <ul class="permissions-list">
          {t.permissions.items.map((item: { name: string; reason: string }) => (
            <li><strong>{item.name}</strong>: {item.reason}</li>
          ))}
        </ul>
        <p class="section-desc">{t.permissions.privacy}</p>
      </div>
    </section>

    <!-- CapsLock -->
    <section class="capslock" id="capslock">
      <div class="container">
        <h2 class="section-title">{t.capslock.heading}</h2>
        <p class="section-desc">{t.capslock.intro}</p>
        <ol>
          {t.capslock.steps.map((step: string) => (
            <li>{step}</li>
          ))}
        </ol>
        <p class="section-desc">{t.capslock.note}</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="faq">
      <div class="container">
        <h2 class="section-title">{t.faq.heading}</h2>
        <dl class="faq-list">
          {t.faq.items.map((item: { question: string; answer: string }) => (
            <div class="faq-item">
              <dt>Q. {item.question}</dt>
              <dd>A. {item.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  </main>

  <style>
    .container {
      max-width: 48rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .hero {
      padding: 4rem 1.5rem 3rem;
    }

    .hero-inner {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      justify-content: center;
    }

    .hero-icon {
      width: 220px;
      height: 220px;
      flex-shrink: 0;
      animation: dissolveIn 1.2s ease-out both;
    }

    @keyframes dissolveIn {
      0% {
        opacity: 0;
        filter: blur(12px);
        transform: scale(0.9);
      }
      100% {
        opacity: 1;
        filter: blur(0);
        transform: scale(1);
      }
    }

    .hero-text {
      text-align: left;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-title {
      font-size: 2.8rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #1a3d5c;
      line-height: 1.1;
    }

    .hero-subtitle {
      margin-top: 0.5rem;
      font-size: 1.15rem;
      color: #3a8fb7;
      line-height: 1.4;
    }

    .hero-action {
      margin-top: 2rem;
      text-align: center;
    }

    .btn-download {
      display: inline-block;
      width: 50%;
      padding: 0.75rem 2rem;
      background: linear-gradient(135deg, #5cc4d8, #3a8fb7);
      color: #fff;
      border-radius: 8px;
      font-size: 1.05rem;
      font-weight: 600;
      text-align: center;
      transition: opacity 0.2s;
    }

    .btn-download,
    .btn-download:hover,
    .btn-download:visited {
      text-decoration: none;
    }

    .btn-download:hover {
      opacity: 0.85;
    }

    .hero-meta {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: #3d7a90;
    }

    .hero-meta a,
    .hero-meta a:visited {
      color: #3a8fb7;
    }

    .section-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .section-desc {
      color: #3d7a90;
      margin-bottom: 1.5rem;
    }

    section {
      padding: 3rem 0;
    }

    section:nth-child(even) {
      background: #eaf6fa;
    }

    .feature-row {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .feature-row--reverse {
      flex-direction: row-reverse;
    }

    .feature-text {
      flex: 1;
    }

    .feature-text h3 {
      font-size: 1.2rem;
      margin-bottom: 0.4rem;
      color: #1a3d5c;
    }

    .feature-emoji {
      font-size: 1.4rem;
      margin-right: 0.25rem;
    }

    .feature-desc {
      padding-left: 2rem;
    }

    .feature-desc p {
      font-size: 0.95rem;
      color: #3d7a90;
    }

    .feature-screenshot {
      width: 280px;
      height: 210px;
      flex-shrink: 0;
      border-radius: 8px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #eaf6fa;
    }

    .screenshot-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .steps {
      counter-reset: step;
      list-style: none;
      padding: 0;
    }

    .step {
      counter-increment: step;
      position: relative;
      padding-left: 2.5rem;
      margin-bottom: 1.5rem;
    }

    .step::before {
      content: counter(step);
      position: absolute;
      left: 0;
      top: 0;
      width: 1.75rem;
      height: 1.75rem;
      background: #3a8fb7;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .step h3 {
      font-size: 1.05rem;
      margin-bottom: 0.25rem;
    }

    .step p {
      font-size: 0.95rem;
      color: #3d7a90;
    }

    .permissions-list {
      padding-left: 1.25rem;
    }

    .permissions-list li {
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
    }

    .faq-list {
      margin: 0;
    }

    .faq-item {
      border-bottom: 1px solid #c8e2ec;
      padding: 1rem 0;
    }

    .faq-item dt {
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .faq-item dd {
      margin: 0;
      color: #3d7a90;
      font-size: 0.95rem;
    }

    @media (max-width: 600px) {
      .hero-inner {
        flex-direction: column;
        text-align: center;
      }

      .hero-text {
        text-align: center;
      }

      .hero-title {
        font-size: 1.75rem;
      }

      .hero-subtitle {
        font-size: 1.05rem;
      }

      .section-title {
        font-size: 1.35rem;
      }

      .feature-row,
      .feature-row--reverse {
        flex-direction: column;
      }

      .feature-screenshot {
        max-width: 100%;
      }
    }
  </style>
</Layout>
